# ------------------------------------------------------------------------------
# Distributed Rate Limiter - Environment Configuration
# ------------------------------------------------------------------------------
# Default Fallback Variables
# When running locally via Docker Compose, these values are used automatically.
# ------------------------------------------------------------------------------

# The port the Spring Boot application will listen on natively
PORT=8080

# The local generic host mapping for Redis (Used when REDIS_URL is totally empty)
REDIS_HOST=localhost
REDIS_PORT=6380

# ------------------------------------------------------------------------------
# Production Cloud Variables (Render, AWS, Upstash, etc.)
# ------------------------------------------------------------------------------

# OVERRIDE: If you provide a full connection URL here, it overrides HOST and PORT.
# This must be provided when connecting to a managed Redis instance like Upstash.
# Example: rediss://default:your-secure-password@us1-upstash-server.upstash.io:32412
REDIS_URL=
